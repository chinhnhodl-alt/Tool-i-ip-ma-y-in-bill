name: printer_ip_tool
description: Doi IP may in bill/tem/wifi (XP, Zywell, HPRT) khong can cung lop mang.
publish_to: "none"
version: 1.0.0+1

environment:
  sdk: ">=3.0.0 <4.0.0"
  flutter: ">=3.10.0"

dependencies:
  flutter:
    sdk: flutter
  cupertino_icons: ^1.0.6
  network_info_plus: ^5.0.3
  permission_handler: ^11.3.1
  shared_preferences: ^2.2.3

dev_dependencies:
  flutter_lints: ^3.0.0

flutter:
  uses-material-design: true
